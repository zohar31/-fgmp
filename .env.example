# Public site URL
NEXT_PUBLIC_SITE_URL=https://fgmp.net

# WhatsApp number for CTA buttons (international format, no +)
NEXT_PUBLIC_WHATSAPP_NUMBER=972585222227

# Email notifications (Resend) — get key at https://resend.com
RESEND_API_KEY=
NOTIFICATIONS_TO_EMAIL=a0545911111@gmail.com
NOTIFICATIONS_FROM_EMAIL=noreply@fgmp.net

# OpenAI for AI agent — keep server-side only
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Upstash Redis (rate-limit). On Vercel, install the Upstash integration
# and these are populated automatically. For local dev, leave empty —
# code falls back to in-memory limiter.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# GTM (optional) — leave empty to disable
NEXT_PUBLIC_GTM_ID=

# Meta Pixel (optional)
NEXT_PUBLIC_META_PIXEL_ID=
