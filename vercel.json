{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["fra1"],
  "functions": {
    "app/api/chat/route.ts": {
      "maxDuration": 60
    },
    "app/api/account/settings/route.ts": {
      "maxDuration": 15
    },
    "app/api/account/cancel/route.ts": {
      "maxDuration": 15
    },
    "app/api/cron/recurring-billing/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/recurring-billing",
      "schedule": "0 6 * * *"
    }
  ]
}
