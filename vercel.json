{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["fra1"],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.fgmp.net" }],
      "destination": "https://fgmp.net/:path*",
      "permanent": true
    }
  ],
  "functions": {
    "app/api/chat/route.ts": {
      "maxDuration": 60
    },
    "app/api/account/settings/route.ts": {
      "maxDuration": 15
    },
    "app/api/account/cancel/route.ts": {
      "maxDuration": 15
    },
    "app/api/cron/recurring-billing/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/recurring-billing",
      "schedule": "0 6 * * *"
    }
  ]
}
